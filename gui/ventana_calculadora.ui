   <string notr="true">QDialog {
    background-color: #F5F3FF; /* fondo lila muy claro */
    font-family: &quot;Segoe UI&quot;, &quot;Arial&quot;;
    font-size: 12pt;
}

/* Etiquetas */
QLabel {
    color: #4B3F72; /* lila oscuro elegante */
    font-weight: 500;
}

QLabel#label_resultado {
    color: #4B3F72; /* lila oscuro elegante */
	font-size: 48pt;
    font-weight: 500;
}

/* Campos de texto */
QLineEdit {
    background-color: #FFFFFF;
    border: 1px solid #D6CCF2;
    border-radius: 8px;
    padding: 6px;
    color: #333333;
}

QLineEdit:focus {
    border: 1px solid #A78BFA; /* lila más intenso al enfocar */
    background-color: #FAF9FF;
}

/* Botones */
QPushButton {
    background-color: #C4B5FD; /* lila suave */
    color: #FFFFFF;
    border: none;
    border-radius: 10px;
    padding: 8px 16px;
    font-weight: 600;
}

QPushButton:hover {
    background-color: #A78BFA;
}

QPushButton:pressed {
    background-color: #8B5CF6;
}

/* Botón secundario (opcional con objectName) */
QPushButton#secondaryButton {
    background-color: transparent;
    color: #6D5BA6;
    border: 1px solid #C4B5FD;
}

QPushButton#secondaryButton:hover {
    background-color: #EDE9FE;
}</string>
